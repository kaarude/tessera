# Tessera — copy this file to `.env` and fill in the values.

# ── Core ──────────────────────────────────────────────────────────────────

# Postgres connection string. The schema is `public` by default.
DATABASE_URL="postgresql://tessera:tessera@localhost:5432/tessera?schema=public"

# Session encryption key. Generate one with: npm run init
# It must be at least 32 characters and NOT the example value or the app
# will refuse to start.
SESSION_SECRET="change-me-to-a-32-plus-character-random-string"

# Public URL of the app. Used for absolute links in notifications and
# password-reset emails (when those land). For local dev, http://localhost:3000.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── S3-compatible object storage ──────────────────────────────────────────

# The default endpoint assumes a local MinIO instance. For AWS S3, use
# https://s3.us-east-1.amazonaws.com (and remove S3_FORCE_PATH_STYLE).
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio12345"
S3_BUCKET="tessera"
# Set to "true" when using MinIO or a local non-AWS S3-compatible store.
# Leave unset for AWS S3.
S3_FORCE_PATH_STYLE="true"

# ── Optional ──────────────────────────────────────────────────────────────

# Set to "1" to seed the database with demo data on first boot.
AUTO_SEED="0"

# Node environment. "production" hides verbose error output.
NODE_ENV="development"
