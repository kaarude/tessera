    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.2",
    "rehype-highlight": "^7.0.2",
