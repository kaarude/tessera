# This file lives here to keep it out of the Docker build context.
# The `docker/` directory is NOT ignored because the Dockerfile COPYs
# docker/entrypoint.sh from it.
.git
.gitignore
.env
.env.*
!.env.example
node_modules
.next
out
build
coverage
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
playwright-report
test-results
.vscode
.idea
README.md
docs/
tests/
scripts/
.dockerignore
Dockerfile
docker-compose.yml
